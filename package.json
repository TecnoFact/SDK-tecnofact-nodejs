{
  "name": "@tecnofact/sdk-nodejs",
  "version": "1.0.0",
  "description": "SDK oficial de Node.js para la integración con el servicio de Timbrado CFDI 4.0 de TecnoFact",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint && npm run test",
    "preversion": "npm run lint && npm run test",
    "version": "npm run format && git add -A src",
    "postversion": "git push && git push --tags"
  },
  "keywords": [
    "tecnofact",
    "cfdi",
    "facturacion",
    "sat",
    "mexico",
    "timbrado",
    "factura-electronica",
    "pac"
  ],
  "author": "TecnoFact",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TecnoFact/SDK-tecnofact-nodejs.git"
  },
  "bugs": {
    "url": "https://github.com/TecnoFact/SDK-tecnofact-nodejs/issues"
  },
  "homepage": "https://github.com/TecnoFact/SDK-tecnofact-nodejs#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=14.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^30.3.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  }
}
